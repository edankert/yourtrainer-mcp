<?xml version="1.0" ?>
<workout_file>
  <author>yourtrainer-mcp</author>
  <name>Golden Sweet Spot 3x12</name>
  <description>Canonical golden workout for regression tests</description>
  <sportType>bike</sportType>
  <workout>
    <Warmup Duration="600" PowerLow="0.45" PowerHigh="0.75"/>
    <IntervalsT Repeat="3" OnDuration="720" OffDuration="300" OnPower="0.9" OffPower="0.55"/>
    <Cooldown Duration="420" PowerLow="0.6" PowerHigh="0.4"/>
  </workout>
</workout_file>
